VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ENV=development

# Read by the Supabase CLI (supabase start) from a root .env file.
# Create a GitHub OAuth App at https://github.com/settings/developers with
# callback URL http://127.0.0.1:54321/auth/v1/callback for local development.
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
